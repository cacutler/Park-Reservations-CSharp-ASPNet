@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}
<style>
    .hero {
        text-align: center;
        padding: 4rem 2rem 3rem;
        background: linear-gradient(160deg, var(--forest) 0%, var(--moss) 60%, var(--sage) 100%);
        border-radius: 18px;
        color: var(--white);
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
    }
    .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23a8c5b0' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.4;
    }
    .hero-emoji {
        font-size: 3.5rem;
        display: block;
        margin-bottom: 1rem;
        position: relative;
    }
    .hero h1 {
        font-family: 'Playfair Display', serif;
        font-size: 3rem; margin-bottom: 0.75rem;
        position: relative;
    }
    .hero p {
        font-size: 1.1rem;
        opacity: 0.82;
        max-width: 500px;
        margin: 0 auto 2rem;
        position: relative;
        line-height: 1.65;
    }
    .hero-buttons {
        display: flex;
        gap: 0.85rem;
        justify-content: center;
        flex-wrap: wrap;
        position: relative;
    }
    .hero-btn {
        padding: 0.7rem 1.75rem;
        border-radius: 9px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.18s;
        border: none;
    }
    .hero-btn-primary {
        background: var(--white);
        color: var(--forest);
    }
    .hero-btn-primary:hover {
        background: var(--cream);
        transform: translateY(-1px);
    }
    .hero-btn-outline {
        background: transparent;
        color: var(--white);
        border: 2px solid rgba(255,255,255,0.5);
    }
    .hero-btn-outline:hover {
        background: rgba(255,255,255,0.12);
        border-color: var(--white);
    }
    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.25rem;
        margin-bottom: 3rem;
    }
    .feature-card {
        background: var(--white);
        border: 1px solid var(--parchment);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
    }
    .feature-card .icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
        display: block;
    }
    .feature-card h3 {
        font-family: 'Playfair Display', serif;
        color: var(--forest);
        margin-bottom: 0.4rem;
        font-size: 1.05rem;
    }
    .feature-card p {
        color: var(--stone);
        font-size: 0.84rem;
        line-height: 1.55;
    }
</style>
<section class="hero">
    <span class="hero-emoji">🌿</span>
    <h1>Reserve Your Park Space</h1>
    <p>Browse parks across cities, check availability, and book your perfect outdoor experience.</p>
    <div class="hero-buttons">
        <a href="/Parks" class="hero-btn hero-btn-primary">Browse Parks</a>
        <a href="/Register" class="hero-btn hero-btn-outline" id="hero-register">Create Account</a>
    </div>
</section>
<div class="features">
    <div class="feature-card">
        <span class="icon">🗺️</span>
        <h3>Explore Parks</h3>
        <p>Discover parks from cities across the region and view their schedules.</p>
    </div>
    <div class="feature-card">
        <span class="icon">📅</span>
        <h3>Easy Reservations</h3>
        <p>Book your time slot in minutes. Manage and update your reservations anytime.</p>
    </div>
    <div class="feature-card">
        <span class="icon">✅</span>
        <h3>Quick Approval</h3>
        <p>City admins review requests promptly to confirm your outdoor plans.</p>
    </div>
    <div class="feature-card">
        <span class="icon">🏙️</span>
        <h3>City Managed</h3>
        <p>Each city's parks are managed by dedicated local administrators.</p>
    </div>
</div>
<script>
    if (localStorage.getItem('token')) {
        document.getElementById('hero-register').textContent = 'My Reservations';
        document.getElementById('hero-register').href = '/Reservations';
    }
</script>