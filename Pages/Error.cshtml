@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}
<div style="text-align:center; padding:4rem 2rem;">
    <span style="font-size:3rem; display:block; margin-bottom:1rem;">⚠️</span>
    <h1 style="font-family:'Playfair Display',serif; color:var(--forest); margin-bottom:0.5rem;">Something went wrong</h1>
    <p class="text-muted" style="margin-bottom:2rem;">We're sorry for the inconvenience.</p>
    @if (Model.ShowRequestId) {
        <p class="text-muted" style="font-size:0.8rem; font-family:monospace; background:var(--parchment); display:inline-block; padding:0.4rem 0.8rem; border-radius:6px;">Request ID: @Model.RequestId</p>
    }
    <br/><br/>
    <a href="/" class="btn btn-primary">Go Home</a>
</div>